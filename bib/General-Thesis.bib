@inproceedings{Metz2024:UltraEthernet,
  title = {Empowering {{AI Workloads}} in {{Ultra Ethernet Consortium}}},
  shorttitle = {{{UltraEthernet}}},
  booktitle = {2024 {{IEEE Photonics Society Summer Topicals Meeting Series}} ({{SUM}})},
  author = {Metz, J},
