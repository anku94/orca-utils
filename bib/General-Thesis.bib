  pages = {1--2},
  issn = {2376-8614},
  doi = {10.1109/SUM60964.2024.10614558},
  url = {https://ieeexplore.ieee.org/document/10614558/},
  urldate = {2025-07-09},
  abstract = {The rapid advancements and widespread enthusiasm surrounding artificial intelligence (AI) have underscored the need to understand the intricacies of AI workloads and their impact on the underlying hardware. This paper discusses the Ultra Ethernet Consortium (UEC), a coalition focused on optimizing Ethernet architecture to meet the specific demands of AI and high-performance computing (HPC) workloads. Traditional Ethernet, known for its modular OSI layered structure, faces new challenges due to the scale, latency, and reliability requirements imposed by AI. AI workloads are complex and data-intensive, requiring efficient movement between memory, processors, and storage, which magnifies the importance of physical layer trade-offs such as power consumption, temperature stability, and distance effects. The UEC aims to refine the Ethernet stack, particularly the transport layer, to mitigate errors and inefficiencies that can significantly impact AI performance. This paper concludes by emphasizing the necessity for a paradigm shift in engineering practices to accommodate the evolving needs of AI and Ultra Ethernet, advocating for adaptive, interdisciplinary, and innovative approaches.},
  eventtitle = {2024 {{IEEE Photonics Society Summer Topicals Meeting Series}} ({{SUM}})},
  keywords = {Architecture,Artificial Intelligence,Ethernet,High performance computing,Memory management,Physical layer,Physical Layer,Power demand,Program processors,Reliability,Silicon Photonics},
  file = {/Users/schwifty/Library/CloudStorage/GoogleDrive-ankushj@andrew.cmu.edu/My Drive/MiscNotes/08 Zotero/General-Thesis/2024_metz_empowering_ai_workloads_in_ultra_ethernet_consortium.pdf}
}

