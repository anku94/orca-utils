  nameatype = {collaborator},
  abstract = {Network interference between applications causes unintended slowdown of important workloads and must be managed effectively to ensure performance predictability. Slingshot networks will provide quality-of-service (QoS) using traffic classes for more controlled allocation of bandwidth, simultaneously meeting the varying needs of multiple workloads. The usability of this QoS feature has not been widely studied on HPC systems and needs to be tested and tuned for DOE's upcoming Exascale systems.},
