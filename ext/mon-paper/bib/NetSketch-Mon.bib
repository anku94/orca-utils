  booktitle = {Proceedings of the 25th {{Symposium}} on {{Operating Systems Principles}}},
  author = {Mace, Jonathan and Roelke, Ryan and Fonseca, Rodrigo},
  date = {2015-10-04},
  series = {{{SOSP}} '15},
  pages = {378--393},
