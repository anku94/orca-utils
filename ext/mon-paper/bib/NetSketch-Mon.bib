@inproceedings{Isaac2015:RecoveringLogicalStructure,
  title = {Recovering Logical Structure from {{Charm}}++ Event Traces},
  booktitle = {Proceedings of the {{International Conference}} for {{High Performance Computing}}, {{Networking}}, {{Storage}} and {{Analysis}}},
  author = {Isaacs, Katherine E. and Bhatele, Abhinav and Lifflander, Jonathan and Böhme, David and Gamblin, Todd and Schulz, Martin and Hamann, Bernd and Bremer, Peer-Timo},
