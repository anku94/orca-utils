@incollection{Loren2008:RMOST,
  title = {{{RMOST}}: {{A Shared Memory Model}} for {{Online Steering}}},
  shorttitle = {{{RMOST}}},
  booktitle = {Computational {{Science}} – {{ICCS}} 2008},
  author = {Lorenz, Daniel and Buchholz, Peter and Uebing, Christian and Walkowiak, Wolfgang and Wismüller, Roland},
  editor = {Bubak, Marian and Van Albada, Geert Dick and Dongarra, Jack and Sloot, Peter M. A.},
  editora = {{Hutchison} and {Kanade} and {Kittler} and {Kleinberg} and {Mattern} and {Mitchell} and {Naor} and {Nierstrasz} and {Pandu Rangan} and {Steffen} and {Sudan} and {Terzopoulos} and {Tygar} and {Vardi} and {Weikum}},
  editoratype = {redactor},
  date = {2008},
  volume = {5103},
  pages = {223--232},
  publisher = {Springer Berlin Heidelberg},
  location = {Berlin, Heidelberg},
  doi = {10.1007/978-3-540-69389-5_26},
  url = {https://link.springer.com/10.1007/978-3-540-69389-5_26},
  urldate = {2026-03-06},
  abstract = {Online steering means to visualize the current state of an application which includes application data and/or performance data, and to modify data in the application. Thus, in online steering the application as well as the steering tool must concurrently access and modify the same data at run time. In this paper a new model for online steering is presented which models the mechanism of online steering as access to a distributed shared memory. The integrity requirements of the steered application are analyzed. The integrity can be ensured through an appropriate consistency model. Finally, the online steering system RMOST is presented which is based on the distributed shared memory model and can be used to steer Grid jobs from the High Energy Physics experiment ATLAS.},
  isbn = {978-3-540-69388-8 978-3-540-69389-5},
  langid = {english},
  file = {/Users/schwifty/Library/CloudStorage/GoogleDrive-ankushj@andrew.cmu.edu/My Drive/MiscNotes/08 Zotero/NetSketch-Mon/steer/2008_lorenz_et_al_rmost_a_shared_memo.pdf}
}

@article{Loren2010:SteeringSequentialJobs,
  title = {Steering of Sequential Jobs with a Distributed Shared Memory Based Model for Online Steering},
  author = {Lorenz, Daniel and Buchholz, Peter and Uebing, Christian and Walkowiak, Wolfgang and Wismüller, Roland},
  date = {2010-01},
  journaltitle = {Future Generation Computer Systems},
  shortjournal = {Future Generation Computer Systems},
  volume = {26},
  number = {1},
  pages = {155--161},
  issn = {0167739X},
  doi = {10.1016/j.future.2009.05.016},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0167739X09000685},
  urldate = {2026-03-06},
  abstract = {Online steering systems allow one to retrieve application data like intermediate results for visualization, and to modify parameters during the run-time of the application. While most steering systems use a client/server paradigm, online steering can favorably be modeled as a distributed shared memory with concurrent access by the application and the online steerer. In this paper, this idea is formalized, focusing on the exploration of the consistency models and protocols for the distributed shared memory. The behavior of the steering system is described by consistency models, which also guarantee the data integrity of the application, both within a single process and between multiple application processes. Depending on the integrity requirements, applications can choose the proper model and protocol. The performance of our protocols is evaluated with a synthetic workload, which shows that the newly developed delayed weak consistency is faster than the special weak consistency. Furthermore, the results prove that the invalidate protocols of both consistency models are able to adapt themselves to the workload.},
  langid = {english},
  file = {/Users/schwifty/Library/CloudStorage/GoogleDrive-ankushj@andrew.cmu.edu/My Drive/MiscNotes/08 Zotero/NetSketch-Mon/steer/2010_lorenz_et_al_steering_of_sequenti.pdf}
}

