@inproceedings{Gupta2018:Sonata,
  title = {Sonata: Query-Driven Streaming Network Telemetry},
  shorttitle = {Sonata},
  booktitle = {Proceedings of the 2018 {{Conference}} of the {{ACM Special Interest Group}} on {{Data Communication}}},
  author = {Gupta, Arpit and Harrison, Rob and Canini, Marco and Feamster, Nick and Rexford, Jennifer and Willinger, Walter},
  date = {2018-08-07},
  pages = {357--371},
