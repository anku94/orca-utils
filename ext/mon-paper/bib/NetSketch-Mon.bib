  shorttitle = {{{OTF2}}},
  booktitle = {Advances in {{Parallel Computing}}},
  author = {{Eschweiler Dominic} and {Wagner Michael} and {Geimer Markus} and {Kn\&uuml;pfer Andreas} and {Nagel Wolfgang E.} and {Wolf Felix}},
