@article{Meles2024:Asteptowardsthefinalfrontier,
  title = {A Step towards the Final Frontier: {{Lessons}} Learned from Acceptance Testing of the First {{HPE}}/{{Cray EX}} 3000 System at {{ORNL}}},
  shorttitle = {A Step towards the Final Frontier},
  author = {Melesse Vergara, Verónica G. and Budiardja, Reuben and Peltz, Paul and Niles, Jeffery and Zimmer, Christopher and Dietz, Daniel and Fuson, Christopher and Liu, Hong and Newman, Paul and Simmons, James and Muzyn, Christopher},
  date = {2024-02},
  journaltitle = {Concurrency and Computation: Practice and Experience},
  shortjournal = {Concurrency and Computation},
