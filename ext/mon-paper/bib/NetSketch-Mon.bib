@inproceedings{Kelly2020:Chimbuko,
  title = {Chimbuko: {{A Workflow-Level Scalable Performance Trace Analysis Tool}}},
  shorttitle = {Chimbuko},
  booktitle = {{{ISAV}}'20 {{In Situ Infrastructures}} for {{Enabling Extreme-Scale Analysis}} and {{Visualization}}},
  author = {Kelly, Christopher and Ha, Sungsoo and Huck, Kevin and Van Dam, Hubertus and Pouchard, Line and Matyasfalvi, Gyorgy and Tang, Li and D'Imperio, Nicholas and Xu, Wei and Yoo, Shinjae and Van Dam, Kerstin Kleese},
  date = {2020-12-02},
  series = {{{ISAV}}'20},
