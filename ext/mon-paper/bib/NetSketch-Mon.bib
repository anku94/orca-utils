@article{Wang2023:LosslessMPITracing,
  title = {Near-{{Lossless MPI Tracing}} and {{Proxy Application Autogeneration}}},
  author = {Wang, Chen and Guo, Yanfei and Balaji, Pavan and Snir, Marc},
