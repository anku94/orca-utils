}

@online{Karni2016:KLLSketch,
  title = {Optimal {{Quantile Approximation}} in {{Streams}}},
  shorttitle = {{{KLLSketch}}},
  author = {Karnin, Zohar and Lang, Kevin and Liberty, Edo},
  date = {2016-04-05},
  eprint = {1603.05346},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.1603.05346},
  url = {http://arxiv.org/abs/1603.05346},
  urldate = {2026-02-11},
  abstract = {This paper resolves one of the longest standing basic problems in the streaming computational model. Namely, optimal construction of quantile sketches. An \$\textbackslash varepsilon\$ approximate quantile sketch receives a stream of items \$x\_1,\textbackslash ldots,x\_n\$ and allows one to approximate the rank of any query up to additive error \$\textbackslash varepsilon n\$ with probability at least \$1-δ\$. The rank of a query \$x\$ is the number of stream items such that \$x\_i \textbackslash le x\$. The minimal sketch size required for this task is trivially at least \$1/\textbackslash varepsilon\$. Felber and Ostrovsky obtain a \$O((1/\textbackslash varepsilon)\textbackslash log(1/\textbackslash varepsilon))\$ space sketch for a fixed \$δ\$. To date, no better upper or lower bounds were known even for randomly permuted streams or for approximating a specific quantile, e.g.,\textbackslash{} the median. This paper obtains an \$O((1/\textbackslash varepsilon)\textbackslash log \textbackslash log (1/δ))\$ space sketch and a matching lower bound. This resolves the open problem and proves a qualitative gap between randomized and deterministic quantile sketching. One of our contributions is a novel representation and modification of the widely used merge-and-reduce construction. This subtle modification allows for an analysis which is both tight and extremely simple. Similar techniques should be useful for improving other sketching objectives and geometric coreset constructions.},
  pubstate = {prepublished},
  keywords = {Computer Science - Data Structures and Algorithms},
  file = {/Users/schwifty/Library/CloudStorage/GoogleDrive-ankushj@andrew.cmu.edu/My Drive/MiscNotes/08 Zotero/NetSketch-Mon/misc/2016_karnin_et_al_optimal_quantile_app.pdf;/Users/schwifty/Zotero/storage/M6Y93VDM/1603.html}
}

