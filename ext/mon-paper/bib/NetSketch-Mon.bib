  booktitle = {2024 {{IEEE}} 20th {{International Conference}} on E-{{Science}} (e-{{Science}})},
  author = {Nicolae, Bogdan and Wozniak, Justin M. and Bicer, Tekin and Nguyen, Hai and Patel, Parth and Pan, Haochen and Gueroudji, Amal and Gonthier, Maxime and Hayot-Sasson, Valerie and Huerta, Eliu and Chard, Kyle and Chard, Ryan and Dorier, Matthieu and Rao, Nageswara S. V. and Al-Najjar, Anees and Corsi, Alessandra and Foster, Ian},
