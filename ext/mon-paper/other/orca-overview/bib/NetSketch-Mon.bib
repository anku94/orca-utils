@inproceedings{Ulmer2023:ExtendingComposableDatab,
  title = {Extending {{Composable Data Services}} into {{SmartNICs}}},
  booktitle = {2023 {{IEEE International Parallel}} and {{Distributed Processing Symposium Workshops}} ({{IPDPSW}})},
