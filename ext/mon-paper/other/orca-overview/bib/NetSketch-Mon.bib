  url = {https://ieeexplore.ieee.org/document/9308656/?arnumber=9308656},
  urldate = {2024-11-18},
  abstract = {The Message-Passing Interface (MPI) is the de-facto standard for designing and executing applications on massively parallel hardware. MPI collectives provide a convenient abstraction for multiple processes/threads to communicate with one another. Mellanox's HDR InfiniBand switches pro-vide Scalable Hierarchical Aggregation and Reduction Protocol (SHARP) capabilities to offload collective communication to the network and reduce CPU involvement in the process. In this paper, we design and implement SHARP-based solutions for MPI Reduce and MPI Barrier in MVAPICH2-X. We evaluate the impact of proposed and existing SHARP-based solutions for MPI\_Allreduce, MPI\_Reduce, and MPI\_Barrier operations have on the performance of the collective operation on the 8th ranked TACC Frontera HPC system. Our experimental evaluation of the SHARP-based designs show up to 5.4X reduction in latency for Reduce, 5.1X for Allreduce, and 7.1X for Barrier at full system scale of 7,861 nodes over a host-based solution.},
  eventtitle = {2020 {{Workshop}} on {{Exascale MPI}} ({{ExaMPI}})},
  keywords = {Fabrics,Hardware,Kernel,MPI,MPI collectives,MPI_Allreduce,MPI_Barrier,MPI_Reduce,Protocols,SHARP,Sockets,Standards,Synchronization},
