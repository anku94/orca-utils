  author = {Newell, Andrew and Skarlatos, Dimitrios and Fan, Jingyuan and Kumar, Pavan and Khutornenko, Maxim and Pundir, Mayank and Zhang, Yirui and Zhang, Mingjun and Liu, Yuanlai and Le, Linh and Daugherty, Brendon and Samudra, Apurva and Baid, Prashasti and Kneeland, James and Kabiljo, Igor and Shchukin, Dmitry and Rodrigues, Andre and Michelson, Scott and Christensen, Ben and Veeraraghavan, Kaushik and Tang, Chunqiang},
