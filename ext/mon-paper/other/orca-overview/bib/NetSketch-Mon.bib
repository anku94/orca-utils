  author = {Ramesh, Bharath and Suresh, Kaushik Kandadi and Sarkauskas, Nick and Bayatpour, Mohammadreza and Hashmi, Jahanzeb Maqbool and Subramoni, Hari and Panda, Dhabaleswar K.},
